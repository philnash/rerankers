{
  "name": "rerankers",
  "version": "0.1.0",
  "description": "Browser-compatible reranking library powered by Transformers.js and open Hugging Face models.",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./langchain": {
      "types": "./dist/langchain.d.ts",
      "import": "./dist/langchain.js"
    },
    "./ai-sdk": {
      "types": "./dist/ai-sdk.d.ts",
      "import": "./dist/ai-sdk.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "demo": "vite --config demo/vite.config.ts",
    "demo:build": "vite build --config demo/vite.config.ts",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run format"
  },
  "keywords": [
    "reranking",
    "transformers.js",
    "huggingface",
    "mixedbread"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@langchain/core": "^1.2.1",
    "ai": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@langchain/core": {
      "optional": true
    },
    "ai": {
      "optional": true
    }
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@langchain/core": "^1.2.1",
    "@types/node": "^24.0.8",
    "ai": "^7.0.15",
    "eslint": "^9.30.0",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  }
}
